{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": false,
    "target": "ES2022",
    "outDir": "dist-electron"
  },
  "include": ["electron", "src/types"]
}
